#!/usr/bin/env python3
"""
codex-usage — Check OpenAI Codex usage limits across all accounts.

Reads all *.auth.json files (and auth.json) from ~/.codex/ and queries
the ChatGPT usage API to show 5-hour and 7-day rate limit windows.

Usage:
  codex-usage              # show all accounts
  codex-usage --json       # raw JSON output
  codex-usage --fix        # switch to the best available account
  codex-usage --fix --json # switch + machine-readable output
  codex-usage --compact    # one-line-per-account table view
  codex-usage --workers 50 # control concurrency (default: 20)

This is a backward-compatible wrapper.  The implementation now lives in
ai_usage.providers.codex.  For cross-provider usage, run: ai-usage
"""
import sys

if "--help" in sys.argv or "-h" in sys.argv:
    print(__doc__.strip())
    sys.exit(0)

# Inject --provider codex so the unified CLI filters to Codex only
sys.argv.insert(1, "--provider")
sys.argv.insert(2, "codex")

from ai_usage.cli import main
main()
