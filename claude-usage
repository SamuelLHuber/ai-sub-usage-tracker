#!/usr/bin/env python3
"""
claude-usage — Check Anthropic Claude usage limits.

Reads Claude Code OAuth credentials from macOS Keychain,
~/.claude/.credentials.json, or ~/.pi/agent/auth.json and queries
the Anthropic usage API to show 5-hour and 7-day rate limit windows.

Usage:
  claude-usage              # show usage
  claude-usage --json       # machine-readable JSON
  claude-usage --compact    # one-line table view

For cross-provider usage (Codex + Claude), run: ai-usage
"""
import sys

if "--help" in sys.argv or "-h" in sys.argv:
    print(__doc__.strip())
    sys.exit(0)

# Inject --provider claude so the unified CLI filters to Claude only
sys.argv.insert(1, "--provider")
sys.argv.insert(2, "claude")

from ai_usage.cli import main
main()
